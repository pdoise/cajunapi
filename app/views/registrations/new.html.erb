<div class="page-header" style="background-image: url('<%= asset_path 'mardi-gras-pasta.png' %>')">
  <div class="filter"></div>
  <div class="container d-flex justify-content-center py-5">
    <div class="card card-register" style="max-width: 460px;">
      <h3 class="title text-center mb-4">Create Account</h3>

      <%= form_with model: @user, url: signup_path, method: :post do |f| %>
        <div class="row g-2 mb-2">
          <div class="col">
            <label class="text-primary small fw-semibold">First Name</label>
            <%= f.text_field :first, class: "form-control", placeholder: "First" %>
          </div>
          <div class="col">
            <label class="text-primary small fw-semibold">Last Name</label>
            <%= f.text_field :last, class: "form-control", placeholder: "Last" %>
          </div>
        </div>
        <div class="mb-2">
          <label class="text-primary small fw-semibold">Location</label>
          <%= f.text_field :location, class: "form-control", placeholder: "City, State (optional)" %>
        </div>
        <div class="mb-2">
          <label class="text-primary small fw-semibold">Email</label>
          <%= f.email_field :email, class: "form-control", placeholder: "Email", autocomplete: "email" %>
        </div>
        <div class="mb-2">
          <label class="text-primary small fw-semibold">Password</label>
          <%= f.password_field :password, class: "form-control", placeholder: "Min 6 chars, letters & numbers", autocomplete: "new-password" %>
        </div>
        <div class="mb-3">
          <label class="text-primary small fw-semibold">Confirm Password</label>
          <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Confirm password", autocomplete: "new-password" %>
        </div>
        <%= f.submit "Create Account", class: "btn btn-primary btn-round w-100" %>
      <% end %>

      <div class="text-center mt-3">
        <small class="text-muted">
          Already have an account? <%= link_to "Login", login_path, class: "text-primary fw-semibold" %>
        </small>
      </div>
    </div>
  </div>
</div>
