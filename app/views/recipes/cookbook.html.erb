<div class="bg-primary text-white py-5">
  <div class="container">
    <div class="d-flex align-items-center gap-4 flex-wrap">
      <% if @user.image.attached? %>
        <%= image_tag @user.image,
            class: "rounded-circle border border-3 border-white shadow",
            style: "width: 90px; height: 90px; object-fit: cover;" %>
      <% else %>
        <div class="rounded-circle bg-white text-primary d-flex align-items-center justify-content-center fw-bold fs-2 border border-3 border-white shadow"
             style="width: 90px; height: 90px; min-width: 90px;">
          <%= @user.first[0].upcase %>
        </div>
      <% end %>

      <div class="flex-grow-1">
        <h2 class="fw-bold mb-1"><%= "#{@user.first} #{@user.last}" %></h2>
        <% if @user.location.present? %>
          <p class="mb-1 opacity-75">
            <i class="fas fa-map-marker-alt me-1"></i><%= @user.location %>
          </p>
        <% end %>
        <% if @user.bio.present? %>
          <p class="mb-0 opacity-75"><%= @user.bio %></p>
        <% end %>
      </div>

      <% if current_user == @user %>
        <div class="d-flex flex-column gap-2">
          <%= link_to new_user_recipe_path(@user), class: "btn btn-light btn-round px-4 shadow-sm" do %>
            <i class="fas fa-plus me-1"></i> Add Recipe
          <% end %>
          <%= link_to edit_user_path(@user), class: "btn btn-outline-light btn-round px-4" do %>
            <i class="fas fa-user-pen me-1"></i> Edit Profile
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="bg-light py-5">
  <div class="container">
    <h4 class="fw-semibold mb-4">
      <%= current_user == @user ? "My Recipes" : "#{@user.first}'s Recipes" %>
      <span class="badge bg-primary ms-2 fw-normal"><%= @recipes.count %></span>
    </h4>

    <div class="row g-4">
      <% @recipes.each do |recipe| %>
        <div class="col-lg-4 col-md-6">
          <div class="card h-100 border-0 shadow-sm recipe-card">
            <%= link_to user_recipe_path(@user, recipe), class: "text-decoration-none text-dark" do %>
              <% if recipe.image.attached? %>
                <%= image_tag recipe.image, class: "card-img-top",
                    style: "height: 200px; object-fit: cover;" %>
              <% else %>
                <div class="card-img-top bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center"
                     style="height: 200px;">
                  <i class="fas fa-utensils text-secondary fs-1"></i>
                </div>
              <% end %>
              <div class="card-body">
                <h5 class="card-title fw-semibold mb-1"><%= recipe.name %></h5>
                <p class="card-text text-muted small">
                  <%= truncate(recipe.description, length: 90) %>
                </p>
              </div>
            <% end %>
            <% if current_user == @user %>
              <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                <%= link_to "Edit", edit_user_recipe_path(@user, recipe),
                    class: "btn btn-outline-secondary btn-sm btn-round" %>
                <%= button_to "Delete", user_recipe_path(@user, recipe), method: :delete,
                    class: "btn btn-outline-danger btn-sm btn-round",
                    data: { turbo_confirm: "Delete this recipe?" } %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <% if @recipes.empty? %>
      <div class="text-center py-5 text-muted">
        <i class="fas fa-book-open fs-1 mb-3 d-block opacity-25"></i>
        <p>No recipes yet.</p>
        <% if current_user == @user %>
          <%= link_to "Add your first recipe", new_user_recipe_path(@user),
              class: "btn btn-primary btn-round px-4" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
