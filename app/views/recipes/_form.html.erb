<%= form_with model: [user, recipe], multipart: true do |f| %>
  <div class="mb-3">
    <label class="form-label text-primary fw-semibold">Recipe Name <span class="text-danger">*</span></label>
    <%= f.text_field :name, class: "form-control form-control-lg",
        placeholder: "e.g. Crawfish Étouffée" %>
  </div>

  <div class="mb-3">
    <label class="form-label text-primary fw-semibold">Description</label>
    <%= f.text_area :description, class: "form-control", rows: 2,
        placeholder: "A short description of the dish..." %>
  </div>

  <div class="mb-3" style="max-width: 180px;">
    <label class="form-label text-primary fw-semibold">Cook Time (minutes)</label>
    <%= f.number_field :cooktime, class: "form-control", min: 0, placeholder: "60" %>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-5">
      <label class="form-label text-primary fw-semibold">Ingredients</label>
      <small class="text-muted d-block mb-1">One ingredient per line</small>
      <%= f.text_area :ingredients, class: "form-control", rows: 10,
          placeholder: "1 lb crawfish tails\n1 stick butter\n1 onion, diced\n..." %>
    </div>
    <div class="col-md-7">
      <label class="form-label text-primary fw-semibold">Directions</label>
      <small class="text-muted d-block mb-1">One step per line</small>
      <%= f.text_area :directions, class: "form-control", rows: 10,
          placeholder: "Melt butter in a large skillet over medium heat.\nAdd onion and cook until soft...\n..." %>
    </div>
  </div>

  <div class="mb-4">
    <label class="form-label text-primary fw-semibold">Recipe Photo</label>
    <% if recipe.image.attached? %>
      <div class="mb-2">
        <%= image_tag recipe.image,
            style: "height: 160px; width: 100%; object-fit: cover; border-radius: 8px;" %>
        <small class="text-muted d-block mt-1">Upload a new photo to replace it (optional)</small>
      </div>
    <% end %>
    <%= f.file_field :image, class: "form-control", accept: "image/*" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit recipe.persisted? ? "Save Changes" : "Create Recipe",
        class: "btn btn-primary btn-round px-5" %>
    <%= link_to "Cancel",
        recipe.persisted? ? user_recipe_path(user, recipe) : user_recipes_path(user),
        class: "btn btn-outline-secondary btn-round" %>
  </div>
<% end %>
