<div class="bg-primary text-white py-4">
  <div class="container">
    <h2 class="fw-bold mb-0">Edit Profile</h2>
  </div>
</div>

<div class="bg-light py-5">
  <div class="container">
    <div class="card border-0 shadow-sm p-4" style="max-width: 540px;">
      <%= form_with model: @user, multipart: true do |f| %>
        <div class="text-center mb-4">
          <% if @user.image.attached? %>
            <%= image_tag @user.image,
                class: "rounded-circle border border-3 border-primary",
                style: "width: 90px; height: 90px; object-fit: cover;" %>
          <% else %>
            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold fs-2 mx-auto border border-3 border-primary"
                 style="width: 90px; height: 90px;">
              <%= @user.first[0].upcase %>
            </div>
          <% end %>
          <div class="mt-2">
            <%= f.file_field :image, class: "form-control form-control-sm", accept: "image/*" %>
          </div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col">
            <label class="form-label text-primary fw-semibold">First Name</label>
            <%= f.text_field :first, class: "form-control" %>
          </div>
          <div class="col">
            <label class="form-label text-primary fw-semibold">Last Name</label>
            <%= f.text_field :last, class: "form-control" %>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label text-primary fw-semibold">Location</label>
          <%= f.text_field :location, class: "form-control", placeholder: "City, State" %>
        </div>

        <div class="mb-4">
          <label class="form-label text-primary fw-semibold">Bio</label>
          <%= f.text_area :bio, class: "form-control", rows: 3,
              placeholder: "Tell us a little about yourself..." %>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit "Save Profile", class: "btn btn-primary btn-round px-4" %>
          <%= link_to "Cancel", user_recipes_path(@user),
              class: "btn btn-outline-secondary btn-round" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
