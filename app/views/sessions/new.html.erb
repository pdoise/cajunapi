<div class="page-header" style="background-image: url('<%= asset_path 'pasta2.png' %>')">
  <div class="filter"></div>
  <div class="container d-flex justify-content-center">
    <div class="card card-register">
      <h3 class="title text-center mb-4">Welcome</h3>

      <%= button_to "/auth/facebook", method: :post,
            class: "btn btn-outline-primary btn-round w-100 mb-3",
            data: { turbo: false } do %>
        <i class="fab fa-facebook me-2"></i> Continue with Facebook
      <% end %>

      <div class="text-center text-muted small mb-3">or sign in with email</div>

      <%= form_with url: login_path, method: :post do |f| %>
        <div class="mb-2">
          <label class="text-primary small fw-semibold">Email</label>
          <%= f.email_field :email, class: "form-control", placeholder: "Email", autocomplete: "email" %>
        </div>
        <div class="mb-3">
          <label class="text-primary small fw-semibold">Password</label>
          <%= f.password_field :password, class: "form-control", placeholder: "Password", autocomplete: "current-password" %>
        </div>
        <%= f.submit "Login", class: "btn btn-primary btn-round w-100" %>
      <% end %>

      <div class="text-center mt-3">
        <small class="text-muted">
          Don't have an account? <%= link_to "Sign Up", signup_path, class: "text-primary fw-semibold" %>
        </small>
      </div>
    </div>
  </div>
</div>
