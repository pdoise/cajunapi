<!DOCTYPE html>
<html>
  <head>
    <title>Cajun Cookbook</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <div class="d-flex align-items-center gap-2 me-3">
          <%= link_to "CAJUN COOKBOOK", root_path, class: "navbar-brand me-2" %>
          <a href="https://www.facebook.com/cajuncookbook" class="nav-icon-link" target="_blank" rel="noopener"><i class="fab fa-facebook-f ms-3"></i></a>
          <a href="https://www.instagram.com" class="nav-icon-link" target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a>
          <a href="https://www.twitter.com" class="nav-icon-link" target="_blank" rel="noopener"><i class="fab fa-x-twitter"></i></a>
        </div>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <div class="ms-auto d-flex align-items-center gap-3 py-2 py-lg-0">
            <%= link_to all_recipes_path, class: "nav-search-link" do %>
              <i class="fas fa-search me-1"></i>Search Recipes
            <% end %>
            <% if logged_in? %>
              <%= link_to user_recipes_path(current_user), class: "nav-search-link" do %>
                <i class="fas fa-book-open me-1"></i>My Cookbook
              <% end %>
              <div class="dropdown">
                <a class="nav-search-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="fas fa-user me-1"></i>Profile
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                  <li><%= link_to "Settings", edit_user_path(current_user), class: "dropdown-item" %></li>
                  <li>
                    <%= button_to "Logout", logout_path, method: :delete,
                        class: "dropdown-item text-start border-0 bg-transparent w-100 px-4",
                        data: { turbo: false } %>
                  </li>
                </ul>
              </div>
            <% else %>
              <%= link_to signup_path, class: "nav-search-link" do %>
                <i class="fas fa-user-plus me-1"></i>Sign Up
              <% end %>
              <%= link_to login_path, class: "nav-search-link" do %>
                <i class="fas fa-sign-in-alt me-1"></i>Login
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% flash.each do |type, message| %>
      <% css_class = type.to_s == 'notice' ? 'alert-success' : 'alert-danger' %>
      <div class="alert <%= css_class %> alert-dismissible fade show m-0 rounded-0" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <%= yield %>

    <footer class="border-top bg-white py-3">
      <div class="container d-flex justify-content-between align-items-center">
        <div class="d-flex gap-4">
          <a href="#" class="text-muted text-decoration-none small text-uppercase fw-semibold">Terms</a>
          <a href="#" class="text-muted text-decoration-none small text-uppercase fw-semibold">About</a>
        </div>
        <small class="text-muted">&copy; <%= Date.today.year %>, version 1.0</small>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
