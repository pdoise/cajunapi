<!DOCTYPE html>
<html>
  <head>
    <title>Cajun Cookbook</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom shadow-sm">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand fw-bold text-primary" do %>
          <i class="fa-solid fa-bowl-food me-1"></i> Cajun Cookbook
        <% end %>
        <div class="ms-auto d-flex align-items-center gap-2">
          <%= link_to "Recipes", all_recipes_path, class: "nav-link text-dark me-1" %>
          <% if logged_in? %>
            <%= link_to current_user.first, user_recipes_path(current_user), class: "btn btn-outline-primary btn-sm btn-round" %>
            <%= button_to "Logout", logout_path, method: :delete,
                class: "btn btn-primary btn-sm btn-round",
                data: { turbo: false } %>
          <% else %>
            <%= link_to "Login",   login_path,  class: "btn btn-outline-primary btn-sm btn-round" %>
            <%= link_to "Sign Up", signup_path, class: "btn btn-primary btn-sm btn-round" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% flash.each do |type, message| %>
      <% css_class = type.to_s == 'notice' ? 'alert-success' : 'alert-danger' %>
      <div class="alert <%= css_class %> alert-dismissible fade show m-0 rounded-0" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <%= yield %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
